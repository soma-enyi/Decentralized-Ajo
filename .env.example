# Stellar Network Configuration
NEXT_PUBLIC_STELLAR_NETWORK=testnet
NEXT_PUBLIC_STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
NEXT_PUBLIC_STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Soroban Configuration (Smart Contract)
NEXT_PUBLIC_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
NEXT_PUBLIC_AJO_CONTRACT_ADDRESS=

# Database Configuration
DATABASE_URL=file:./dev.db

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Wallet Configuration
NEXT_PUBLIC_WALLET_NETWORK_DETAILS_PUBLIC_KEY=public
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# ========================================
# Ethereum Sepolia Network Configuration
# ========================================
# Sepolia RPC URL (choose one provider)
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_API_KEY
# Alternative RPC providers:
# SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
# SEPOLIA_RPC_URL=https://1rpc.io/sepolia

# ⚠️  SECURITY WARNING ⚠️
# NEVER commit this file with real private keys to git
# This should only be used for testnet accounts with minimal funds
SEPOLIA_PRIVATE_KEY=your_testnet_private_key_here

# Etherscan API Key for contract verification
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# Optional: Gas reporting
REPORT_GAS=false
COINMARKETCAP_API_KEY=your_coinmarketcap_api_key_here

# Deployed contract addresses (populated after deployment)
NEXT_PUBLIC_SEPOLIA_AJO_FACTORY_ADDRESS=

# Feature Flags
NEXT_PUBLIC_ENABLE_GOVERNANCE=true
NEXT_PUBLIC_ENABLE_PARTIAL_WITHDRAWALS=true

# Email (Resend)
RESEND_API_KEY=re_your_api_key_here

# ─── Contribution Deadline Reminder Scheduler ─────────────────────────────────
# Enable/disable the contribution deadline reminder scheduler
ENABLE_DEADLINE_REMINDERS=true

# Configurable lead time for reminders (in hours) - supports multiple values separated by commas
# Example: "24,1" means send reminders 24 hours and 1 hour before deadline
REMINDER_LEAD_TIME_HOURS=24,1

# Cron schedule for reminder checks (default: every hour)
# Uses node-cron format: https://crontab.guru/
REMINDER_CRON_SCHEDULE=0 * * * *

# Express Server Configuration
PORT=4000
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:3000

# ─── Ethereum / Sepolia Deployment ────────────────────────────────────────────
# Deployer wallet private key (dedicated wallet, never reuse a personal key)
PRIVATE_KEY=0xYOUR_DEPLOYER_PRIVATE_KEY

# RPC endpoint — Alchemy or Infura
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY

# Etherscan API key for contract verification
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY

# Deployed contract addresses (populated after running the deploy script)
NEXT_PUBLIC_AJO_CIRCLE_ADDRESS=
NEXT_PUBLIC_AJO_FACTORY_ADDRESS=
