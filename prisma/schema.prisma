// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String?
  address   String   @unique
  
  // Wallet info
  walletAddress String? @unique
  nonce         String?
  nonceExpiresAt DateTime?
  isWalletVerified Boolean @default(false)
  
  firstName String?
  lastName  String?
  /// Preferred display name (optional; shown instead of email when set)
  username  String? @unique
  /// Email used for product notifications (optional; can differ from login email)
  notificationEmail String?
  phoneNumber String?
  profilePicture String?
  bio       String?
  verified  Boolean  @default(false)
  emailVerifiedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  circles   CircleMember[]
  organizedCircles Circle[] @relation("organizer")
  votes     GovernanceVote[]
  contributions Contribution[]
  withdrawals Withdrawal[]
  refreshTokens RefreshToken[]
  notifications Notification[]
  deadlineReminders DeadlineReminder[]
  verificationTokens VerificationToken[]
  
  // New Ajo Group Relations
  ajos          UserAjo[]
  ajoParticipations UserAjoParticipation[]
  settings      UserSettings?
  activityLogs  ActivityLog[]
}

model VerificationToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model UserSettings {
  id                 String   @id @default(cuid())
  userId             String   @unique
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailAddress       String?
  receiveEmailNotifs Boolean  @default(true)
  showPnlPublicly    Boolean  @default(false)
  theme              String   @default("light")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  rotatedAt DateTime?
  familyId  String   @default(cuid())

  @@index([userId])
  @@index([familyId])
}

model Circle {
  id        String   @id @default(cuid())
  name      String
  description String?
  organizerId String
  organizer User @relation("organizer", fields: [organizerId], references: [id], onDelete: Cascade)
  
  // Circle Configuration
  contributionAmount Float
  contributionFrequencyDays Int @default(7)
  maxRounds Int @default(12)
  currentRound Int @default(1)
  status    CircleStatus @default(ACTIVE)
  
  // Blockchain
  contractAddress String?
  contractDeployed Boolean @default(false)
  onChainId String?
  
  // Metadata
  expectedEndDate DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  members   CircleMember[]
  contributions Contribution[]
  payments  PaymentSchedule[]
  governance GovernanceProposal[]
  withdrawals Withdrawal[]
  ajoParticipants UserAjoParticipation[] @relation("ajoParticipants")
  deadlineReminders DeadlineReminder[]

  @@index([organizerId])
  @@index([status])
  @@index([organizerId, status])
}

enum CircleStatus {
  PENDING
  ACTIVE
  COMPLETED
  CANCELLED
  ACTION_REQUIRED
}

model CircleMember {
  id        String   @id @default(cuid())
  circleId  String
  circle    Circle @relation(fields: [circleId], references: [id], onDelete: Cascade)
  userId    String
  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Member Status
  status    MemberStatus @default(ACTIVE)
  rotationOrder Int @unique
  hasReceivedPayout Boolean @default(false)
  totalContributed Float @default(0)
  totalWithdrawn Float @default(0)
  
  // Tracking
  joinedAt DateTime @default(now())
  leftAt   DateTime?
  @@unique([circleId, userId])
  @@index([circleId])
  @@index([userId])
  @@index([status])
  @@index([userId, status])
}

enum MemberStatus {
  ACTIVE
  INACTIVE
  EXITED
  SUSPENDED
}

model Contribution {
  id        String   @id @default(cuid())
  circleId  String
  circle    Circle @relation(fields: [circleId], references: [id], onDelete: Cascade)
  userId    String
  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  amount    Float
  round     Int
  status    ContributionStatus @default(PENDING)
  
  // Blockchain
  txHash    String?
  
  createdAt DateTime @default(now())
  completedAt DateTime?

  @@index([circleId])
  @@index([userId])
  @@index([userId, createdAt])
  @@index([status])
  @@index([circleId, status])
  @@index([userId, status])
}

enum ContributionStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

model PaymentSchedule {
  id        String   @id @default(cuid())
  circleId  String
  circle    Circle @relation(fields: [circleId], references: [id], onDelete: Cascade)
  
  round     Int
  payeeIndex Int
  expectedAmount Float
  dueDate   DateTime
  
  status    PaymentStatus @default(PENDING)
  paidAt    DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([circleId])
  @@index([status])
  @@index([circleId, status])
}

enum PaymentStatus {
  PENDING
  INITIATED
  COMPLETED
  OVERDUE
  FAILED
}

model GovernanceProposal {
  id        String   @id @default(cuid())
  circleId  String
  circle    Circle @relation(fields: [circleId], references: [id], onDelete: Cascade)
  
  title     String
  description String
  proposalType ProposalType
  status    ProposalStatus @default(PENDING)
  
  // Voting
  votingStartDate DateTime
  votingEndDate DateTime
  requiredQuorum Int @default(50)
  
  // Data (JSON for flexibility)
  proposalData String? // JSON data for different proposal types
  
  createdAt DateTime @default(now())
  
  // Relations
  votes     GovernanceVote[]

  @@index([circleId])
  @@index([status])
  @@index([circleId, status])
}

enum ProposalType {
  RULE_CHANGE
  MEMBER_REMOVAL
  EMERGENCY_PAYOUT
  CIRCLE_DISSOLUTION
  CONTRIBUTION_ADJUSTMENT
}

enum ProposalStatus {
  PENDING
  ACTIVE
  PASSED
  REJECTED
  EXECUTED
}

model GovernanceVote {
  id        String   @id @default(cuid())
  proposalId String
  proposal  GovernanceProposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  userId    String
  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  voteChoice VoteChoice
  
  createdAt DateTime @default(now())
  
  @@unique([proposalId, userId])
  @@index([proposalId])
  @@index([userId])
}

enum VoteChoice {
  YES
  NO
  ABSTAIN
}

model Withdrawal {
  id        String   @id @default(cuid())
  circleId  String
  circle    Circle @relation(fields: [circleId], references: [id], onDelete: Cascade)
  userId    String
  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  amount    Float
  requestedAmount Float // Amount requested before penalty
  penaltyPercentage Float @default(10)
  reason    String?
  status    WithdrawalStatus @default(PENDING)
  
  // Blockchain
  txHash    String?
  createdAt DateTime @default(now())
  approvedAt DateTime?
  completedAt DateTime?

  @@index([circleId])
  @@index([userId])
  @@index([status])
  @@index([circleId, status])
  @@index([userId, status])
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
  CANCELLED
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  
  createdAt DateTime @default(now())
}

/// Off-chain participation record for Ajo groups (many-to-many: User <-> Circle).
/// Mirrors on-chain membership events for consistency.
model UserAjoParticipation {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ajoId     String
  ajo       Circle   @relation("ajoParticipants", fields: [ajoId], references: [id], onDelete: Cascade)

  status    AjoParticipationStatus @default(PENDING)

  /// Set when the join is confirmed on-chain (tx hash from the blockchain event)
  onChainTxHash String?
  /// Timestamp of the on-chain confirmation
  confirmedAt   DateTime?

  joinedAt  DateTime @default(now())
  leftAt    DateTime?

  @@unique([userId, ajoId])
  @@index([userId])
  @@index([ajoId])
  @@index([status])
}

enum AjoParticipationStatus {
  PENDING    // joined off-chain, awaiting on-chain confirmation
  CONFIRMED  // confirmed by on-chain event
  EXITED     // user left the group
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  type      NotificationType
  title     String
  message   String
  read      Boolean  @default(false)

  // Optional link to a related resource
  circleId  String?
  link      String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userId, read])
}

model DeadlineReminder {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  circleId  String
  circle    Circle   @relation(fields: [circleId], references: [id], onDelete: Cascade)

  round     Int
  leadTimeHours Int
  notifiedAt DateTime @default(now())

  @@unique([userId, circleId, round, leadTimeHours])
  @@index([userId])
  @@index([circleId])
  @@index([circleId, round])
}

enum NotificationType {
  CONTRIBUTION_REMINDER
  PAYOUT_TURN
  MEMBER_JOINED
  MEMBER_LEFT
  PROPOSAL_CREATED
  PROPOSAL_RESULT
  CIRCLE_DISSOLVED
  GENERAL
}

// ==========================================
// NEW AJO GROUP MODELS (Issue #102)
// ==========================================

model AjoGroup {
  id              String    @id @default(uuid())
  contractAddress String    @unique
  name            String
  contributionAmt String    // Stored as string to match uint256 from smart contract
  cycleDuration   Int       // Duration in days
  maxMembers      Int
  status          String    @default("OPEN")
  createdAt       DateTime  @default(now())
  
  members         UserAjo[]
  
  @@index([contractAddress])
  @@index([status])
}

model UserAjo {
  userAddress String
  ajoId       String
  
  user        User     @relation(fields: [userAddress], references: [address], onDelete: Cascade)
  ajo         AjoGroup @relation(fields: [ajoId], references: [id], onDelete: Cascade)
  
  @@id([userAddress, ajoId])
  @@index([userAddress])
  @@index([ajoId])
}

model ActivityLog {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action      String
  description String?
  metadata    String?  // JSON string for extra context (circleId, amount, etc.)
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([userId, createdAt])
}
