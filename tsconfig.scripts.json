{
    "compilerOptions": {
        "target": "ES2020",
        "module": "Node16",
        "moduleResolution": "Node16",
        "lib": [
            "ES2020"
        ],
        "types": [
            "node"
        ],
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "strict": true,
        "skipLibCheck": true,
        "outDir": "./dist-scripts"
    },
    "include": [
        "hardhat.config.ts",
        "scripts/**/*.ts"
    ],
    "exclude": [
        "node_modules"
    ]
}